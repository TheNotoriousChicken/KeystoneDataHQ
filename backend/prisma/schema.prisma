generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// The tenant — each paying company gets its own isolated data silo.
model Company {
  id                         String           @id @default(uuid())
  name                       String
  subscriptionTier           SubscriptionTier @default(NONE)
  lemonSqueezyCustomerId     String?
  lemonSqueezySubscriptionId String?          @unique
  subscriptionStatus         String           @default("inactive")
  onboardingCompleted        Boolean          @default(false)
  createdAt                  DateTime         @default(now())
  shopifyShopName            String?
  shopifyToken               String?
  metaAdAccountId            String?
  metaAccessToken            String?
  ga4PropertyId              String?
  ga4Credentials             Json?
  klaviyoApiKey              String?
  logoUrl                    String?
  auditLogs                  AuditLog[]
  integrations               Integration[]
  metricCaches               MetricCache[]
  invites                    TeamInvite[]
  users                      User[]
}

/// A user who can log in and access their company's dashboard.
model User {
  id                   String          @id @default(uuid())
  email                String          @unique
  passwordHash         String
  firstName            String
  lastName             String
  role                 UserRole        @default(ADMIN)
  emailVerified        Boolean         @default(false)
  emailVerifyToken     String?         @unique
  createdAt            DateTime        @default(now())
  companyId            String
  twoFactorEnabled     Boolean         @default(false)
  twoFactorMethod      String          @default("NONE")
  twoFactorSecret      String?
  emailAuthCode        String?
  emailAuthCodeExpires DateTime?
  avatarUrl            String?
  isSuperAdmin         Boolean         @default(false)
  auditLogs            AuditLog[]
  notifications        Notification[]
  passwordResets       PasswordReset[]
  company              Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

/// A password reset token linked to a user.
model PasswordReset {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// A pending team invitation.
model TeamInvite {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

/// An API connection to an external data platform.
model Integration {
  id           String            @id @default(uuid())
  platformName PlatformName
  credentials  Json
  status       IntegrationStatus @default(DISCONNECTED)
  lastSyncedAt DateTime?
  createdAt    DateTime          @default(now())
  companyId    String
  syncError    String?
  syncStatus   String            @default("PENDING")
  company      Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, platformName])
}

/// A global feature flag to enable/disable specific platform features
model FeatureFlag {
  id          String   @id @default(uuid())
  key         String   @unique
  isEnabled   Boolean  @default(false)
  description String?
  updatedAt   DateTime @updatedAt
}

/// A global platform announcement or alert.
model Broadcast {
  id        String    @id @default(uuid())
  message   String
  type      String    @default("INFO")
  isActive  Boolean   @default(true)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
}

/// Cached daily metrics pulled from integrated platforms.
model MetricCache {
  id           String   @id @default(uuid())
  date         DateTime
  totalRevenue Float
  adSpend      Float
  totalOrders  Int
  cac          Float?
  roas         Float?
  visitors     Int?
  emailRevenue Float?
  createdAt    DateTime @default(now())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, date])
}

/// Track user actions across the company for auditing.
model AuditLog {
  id        String   @id @default(uuid())
  action    String
  details   String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  userId    String?
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id])
}

/// User-specific notifications for the bell dropdown / inbox.
model Notification {
  id        String   @id @default(uuid())
  type      String   @default("INFO")
  title     String
  message   String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum SubscriptionTier {
  NONE
  STARTER
  GROWTH
}

enum UserRole {
  ADMIN
  VIEWER
}

enum PlatformName {
  SHOPIFY
  META_ADS
  GOOGLE_ANALYTICS
  KLAVIYO
}

enum IntegrationStatus {
  CONNECTED
  ERROR
  DISCONNECTED
}

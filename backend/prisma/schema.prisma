// ---------------------------------------------------------------------------
// Prisma Schema — Keystone Data HQ
// Multi-tenant B2B SaaS data analytics platform
// ---------------------------------------------------------------------------

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum SubscriptionTier {
  NONE
  STARTER
  GROWTH
}

enum UserRole {
  ADMIN
  VIEWER
}

enum PlatformName {
  SHOPIFY
  META_ADS
  GOOGLE_ANALYTICS
  KLAVIYO
}

enum IntegrationStatus {
  CONNECTED
  ERROR
  DISCONNECTED
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

/// The tenant — each paying company gets its own isolated data silo.
model Company {
  id                          String            @id @default(uuid())
  name                        String
  subscriptionTier            SubscriptionTier  @default(NONE)
  lemonSqueezyCustomerId      String?
  lemonSqueezySubscriptionId  String?           @unique
  subscriptionStatus          String            @default("inactive")
  onboardingCompleted         Boolean           @default(false)
  logoUrl                     String?           // Path to company logo
  createdAt                   DateTime          @default(now())

  // Integration credentials (stored at company level)
  shopifyShopName             String?           // e.g. brand.myshopify.com
  shopifyToken                String?           // Shopify Admin API access token
  metaAdAccountId             String?           // Meta Ad Account ID
  metaAccessToken             String?           // Meta System User Access Token
  ga4PropertyId               String?           // Google Analytics 4 Property ID
  ga4Credentials              Json?             // Google Service Account JSON credentials
  klaviyoApiKey               String?           // Klaviyo Private API Key

  // Relations
  users        User[]
  integrations Integration[]
  metricCaches MetricCache[]
  invites      TeamInvite[]
  auditLogs    AuditLog[]
}

/// A user who can log in and access their company's dashboard.
model User {
  id               String   @id @default(uuid())
  email            String   @unique
  passwordHash     String
  firstName        String
  lastName         String
  role             UserRole @default(ADMIN)
  isSuperAdmin     Boolean  @default(false)
  emailVerified    Boolean  @default(false)
  emailVerifyToken String?  @unique
  avatarUrl        String?  // Path to user avatar
  createdAt        DateTime @default(now())

  // Relations
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Two-Factor Authentication
  twoFactorEnabled     Boolean  @default(false)
  twoFactorMethod      String   @default("NONE") // NONE, APP, EMAIL
  twoFactorSecret      String?  // The TOTP secret for Authenticator Apps
  emailAuthCode        String?  // Temporary hashed OTP for email 2FA
  emailAuthCodeExpires DateTime?

  passwordResets PasswordReset[]
  auditLogs      AuditLog[]
  notifications  Notification[]
}

/// A password reset token linked to a user.
model PasswordReset {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  // Relations
  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// A pending team invitation.
model TeamInvite {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  status    String   @default("PENDING")
  createdAt DateTime @default(now())

  // Relations
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

/// An API connection to an external data platform.
model Integration {
  id           String            @id @default(uuid())
  platformName PlatformName
  credentials  Json              // Stores access tokens, refresh tokens, store URLs
  status       IntegrationStatus @default(DISCONNECTED)
  lastSyncedAt DateTime?
  syncStatus   String            @default("PENDING") // PENDING, SUCCESS, FAILURE
  syncError    String?           // Detailed error message if sync failed
  createdAt    DateTime          @default(now())

  // Relations
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, platformName]) // One integration per platform per company
}

/// A global feature flag to enable/disable specific platform features
model FeatureFlag {
  id          String   @id @default(uuid())
  key         String   @unique
  isEnabled   Boolean  @default(false)
  description String?
  updatedAt   DateTime @updatedAt
}

/// A global platform announcement or alert.
model Broadcast {
  id        String    @id @default(uuid())
  message   String
  type      String    @default("INFO") // INFO, WARNING, CRITICAL
  isActive  Boolean   @default(true)
  expiresAt DateTime? // Optional auto-expiration
  createdAt DateTime  @default(now())
}

/// Cached daily metrics pulled from integrated platforms.
model MetricCache {
  id           String   @id @default(uuid())
  date         DateTime
  totalRevenue Float
  adSpend      Float
  totalOrders  Int
  cac          Float?
  roas         Float?
  visitors     Int?     // Daily website visitors (GA4)
  emailRevenue Float?   // Revenue attributed to email marketing (Klaviyo)
  createdAt    DateTime @default(now())

  // Relations
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, date]) // One row per company per day
}

/// Track user actions across the company for auditing.
model AuditLog {
  id        String   @id @default(uuid())
  action    String   // e.g., "TEAM_INVITE_SENT", "PROFILE_UPDATED"
  details   String?  // Additional context
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  // Relations
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

/// User-specific notifications for the bell dropdown / inbox.
model Notification {
  id        String   @id @default(uuid())
  type      String   @default("INFO") // INFO, SUCCESS, WARNING, ERROR
  title     String
  message   String
  read      Boolean  @default(false)
  link      String?  // Optional relative URL to click through to (e.g. "/dashboard/billing")
  createdAt DateTime @default(now())

  // Relations
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}


